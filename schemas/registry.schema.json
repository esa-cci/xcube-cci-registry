{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://esa-cci.github.io/xcube-cci-registry/schemas/registry.schema.json",
  "title": "xcube-cci dataset registry",
  "type": "object",
  "required": ["schema_version", "datasets"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "datasets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["canonical_id", "collection_id", "representations"],
        "properties": {
          "canonical_id": {
            "type": "string",
            "description": "Stable identifier for this logical dataset entry, including the dataset version where applicable."
          },
          "collection_id": {
            "type": "string",
            "description": "Stable identifier for the product collection or dataset family that groups related dataset versions and variants."
          },
          "title": {
            "type": "string"
          },
          "ecv": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "catalog_url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the dataset entry in the CEDA catalogue."
          },
          "bbox": {
            "type": "array",
            "description": "Spatial extent as [west, south, east, north].",
            "prefixItems": [
              {"type": "number"},
              {"type": "number"},
              {"type": "number"},
              {"type": "number"}
            ],
            "minItems": 4,
            "maxItems": 4
          },
          "time_range": {
            "type": "array",
            "description": "Temporal extent as [start, end].",
            "prefixItems": [
              {"type": ["string", "null"]},
              {"type": ["string", "null"]}
            ],
            "minItems": 2,
            "maxItems": 2
          },
          "supersedes": {
            "type": "array",
            "description": "Canonical IDs of older dataset entries superseded by this entry.",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "superseded_by": {
            "description": "Canonical ID of the newer dataset entry that supersedes this entry, if known.",
            "type": ["string", "null"]
          },
          "representations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["store_id", "data_id"],
              "properties": {
                "store_id": {
                  "type": "string"
                },
                "data_id": {
                  "type": "string"
                },
                "data_type": {
                  "type": "string"
                },
                "descriptor_ref": {
                  "type": "string"
                },
                "descriptor_hash": {
                  "type": "string"
                },
                "reference_path": {
                  "type": "string",
                  "description": "Optional path or URL to a Kerchunk reference file for reference-based representations such as esa-cci-kc."
                },
                "bbox": {
                  "type": "array",
                  "description": "Representation-specific spatial extent overriding the canonical dataset extent.",
                  "prefixItems": [
                    {"type": "number"},
                    {"type": "number"},
                    {"type": "number"},
                    {"type": "number"}
                  ],
                  "minItems": 4,
                  "maxItems": 4
                },
                "time_range": {
                  "type": "array",
                  "description": "Representation-specific temporal extent overriding the canonical dataset extent.",
                  "prefixItems": [
                    {"type": ["string", "null"]},
                    {"type": ["string", "null"]}
                  ],
                  "minItems": 2,
                  "maxItems": 2
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
