{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://esa-cci.github.io/xcube-cci-registry/schemas/registry.schema.json",
  "title": "xcube-cci dataset registry",
  "type": "object",
  "required": ["schema_version", "datasets"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "datasets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["canonical_id", "representations"],
        "properties": {
          "canonical_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "ecv": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "representations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["store_id", "data_id"],
              "properties": {
                "store_id": {
                  "type": "string"
                },
                "data_id": {
                  "type": "string"
                },
                "data_type": {
                  "type": "string"
                },
                "descriptor_ref": {
                  "type": "string"
                },
                "descriptor_hash": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
