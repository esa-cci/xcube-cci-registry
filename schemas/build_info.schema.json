{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://esa-cci.github.io/xcube-cci-registry/schemas/build_info.schema.json",
  "title": "xcube-cci metadata build info",
  "type": "object",
  "required": [
    "generated_at",
    "builder",
    "xcube_cci",
    "xcube",
    "source",
    "outputs",
    "counts"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "builder": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string"},
        "version": {"type": "string"}
      },
      "additionalProperties": true
    },
    "xcube_cci": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "version": {"type": "string"}
      },
      "additionalProperties": true
    },
    "xcube": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "version": {"type": "string"}
      },
      "additionalProperties": true
    },
    "source": {
      "type": "object",
      "additionalProperties": true
    },
    "outputs": {
      "type": "object",
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  },
  "additionalProperties": true
}
